# ─────────────────────────────────────────────────────────────
#  Market Terminal — environment
#  Copy this file to ".env" and fill in the values.
# ─────────────────────────────────────────────────────────────

# REQUIRED for the TERMINAL tab (quotes, profile, metrics, company news, search).
# Get a free key at https://finnhub.io  (Dashboard -> API Key)
FINNHUB_API_KEY=

# Port the local server listens on
PORT=3000

# REQUIRED for the NEWS / SECTORS / WATCHLIST tabs (the AI market-intelligence
# wing). Get a free key (no credit card) at https://console.groq.com/keys
GROQ_API_KEY=
# Optional: override the AI model. Default is llama-3.3-70b-versatile.
# GROQ_MODEL=

# OPTIONAL — only needed for breaking-news push notifications (ALERTS tab).
# Generate a keypair once with:  npx web-push generate-vapid-keys
# Leave blank to simply disable push (the rest of the app still works).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
